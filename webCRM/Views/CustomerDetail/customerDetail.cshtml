                                        <input type="text" class="form-control" placeholder="ตัวอย่าง: 081-234-5678">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-medium small">Line ID</label>
                                        <div class="position-relative">
                                            <input type="text" id="username" class="form-control" placeholder="ตัวอย่าง: @@username">
                                            <i class="bi bi-chevron-down position-absolute top-50 end-0 translate-middle-y me-3 text-muted small pointer-events-none"></i>
                                        </div>
                                    </div>
                                    <div class="col-md-6">

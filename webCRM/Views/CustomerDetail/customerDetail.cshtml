@{
    ViewData["Title"] = "ข้อมูลลูกค้า - CRM";
    ViewData["HeaderTitle"] = "ข้อมูลลูกค้า";
    ViewData["HeaderSubtitle"] = "ดูรายละเอียดลูกค้า";
}

@section Styles {
    <link rel="stylesheet" href="~/css/customerDetail.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
}


    <div class="container-fluid p-4 max-w-custom">
        <!-- Search Area -->
        <div class="bg-white rounded-4 p-4 shadow-sm mb-4 border">
            <div class="row align-items-center">
                <div class="col-md-4 d-flex align-items-center gap-3">
                    <div class="search-icon-circle bg-light-blue text-primary d-flex align-items-center justify-content-center rounded-circle">
                        <i class="bi bi-search fs-3"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold mb-1 text-dark">ค้นหาข้อมูลลูกค้า</h5>
                        <p class="text-muted small mb-0">ค้นหาด้วยเลขบัตรประชาชน / ชื่อ-นามสกุล / ทะเบียนรถ</p>
                    </div>
                </div>
                <div class="col-md-8 mt-3 mt-md-0">
                    <div class="d-flex flex-column flex-md-row gap-3">

                        <div class="input-group search-input-group flex-grow-1">
                            <span class="input-group-text bg-white border-end-0 text-muted px-3">
                                <i class="bi bi-search"></i>
                            </span>
                            <input type="text" id="searchInput" class="form-control border-start-0 ps-0 search-input" placeholder="กรอกเลขบัตรประชาชน / ชื่อ-นามสกุล / ทะเบียนรถ">
                        </div>

                        <button class="btn btn-primary px-4 fw-medium d-flex align-items-center justify-content-center gap-2 text-nowrap flex-shrink-0" id="searchBtn">
                            <i class="bi bi-search"></i> ค้นหา
                        </button>

                        <button class="btn btn-white border px-4 fw-medium d-flex align-items-center justify-content-center gap-2 text-dark text-nowrap flex-shrink-0" id="clearBtn">
                            <i class="bi bi-arrow-clockwise"></i> ล้างค่า
                        </button>

                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-12 col-lg-5 d-flex flex-column gap-4" style="min-height: 0;">
                <div class="search-result">

                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="fw-bold mb-0 text-dark">ผลการค้นหา (<span id="customerCount">0</span>)</h6>
                        @* <i class="bi bi-arrow-clockwise text-muted cursor-pointer fs-5"></i> *@
                    </div>

                    <div class="d-flex flex-md-row flex-column gap-2 mb-2">

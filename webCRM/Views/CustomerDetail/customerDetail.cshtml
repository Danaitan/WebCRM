                                        <tr class="text-muted border-bottom">
                                            <th class="fw-medium pb-2 text-center">ชื่อ-นามสกุล</th>
                                            <th class="fw-medium pb-2 text-center">เลขบัตรประชาชน</th>
                                            <th class="fw-medium pb-2 text-center">ทะเบียนรถ</th>
                                        </tr>
                                    </thead>
                                    <tbody id="searchResultBody">
                                    </tbody>
                                </table>
                                </div>
                            </div>

                            <div id="tab-table-contact" class="d-none d-flex flex-column flex-grow-1 h-100 min-vh-0">

                                    <div id="contact-Micro" class="show active d-flex flex-column flex-grow-1 h-100 min-vh-0">
                                        <table class="table table-borderless search-result-table mb-0 align-middle w-100" id="dt-contact-Micro">
                                            <thead>
                                                <tr class="text-muted border-bottom">
                                                    <th class="fw-medium pb-2 text-center">สัญญาเลขที่</th>
                                                    <th class="fw-medium pb-2 text-center">เลขที่ใบคำขอ</th>
                                                    <th class="fw-medium pb-2 text-center">ประเภทสินเชื่อ</th>
                                                    <th class="fw-medium pb-2 text-center">ประเภทสัญญา</th>
                                                </tr>
                                            </thead>
                                            <tbody></tbody>
                                        </table>
                                    </div>
                                    <div id="contact-MFIN" class="d-none flex-column flex-grow-1 h-100 min-vh-0">
                                        <table class="table table-borderless search-result-table mb-0 align-middle w-100" id="dt-contact-MFIN">
                                            <thead>
                                                <tr class="text-muted border-bottom">
                                                    <th class="fw-medium pb-2 text-center">สัญญาเลขที่</th>
                                                    <th class="fw-medium pb-2 text-center">เลขที่ใบคำขอ</th>
                                                    <th class="fw-medium pb-2 text-center">ประเภทสินเชื่อ</th>
                                                    <th class="fw-medium pb-2 text-center">ประเภทสัญญา</th>
                                                </tr>
                                            </thead>
                                            <tbody></tbody>
                                        </table>
                                    </div>
                                    <div id="contact-MIB" class="d-none flex-column flex-grow-1 h-100 min-vh-0">
                                        <table class="table table-borderless search-result-table mb-0 align-middle w-100" id="dt-contact-MIB">
                                            <thead>
                                                <tr class="text-muted border-bottom">
                                                    <th class="fw-medium pb-2 text-center">สัญญาเลขที่</th>
                                                    <th class="fw-medium pb-2 text-center">เลขที่ใบคำขอ</th>
                                                    <th class="fw-medium pb-2 text-center">ประเภทสินเชื่อ</th>
                                                    <th class="fw-medium pb-2 text-center">ประเภทสัญญา</th>
                                                </tr>
                                            </thead>
                                            <tbody></tbody>
                                        </table>
                                    </div>
                                    
                            </div>

                        </div>

                    </div>
                </div>
                    
            </div>

                <!-- Product Summary -->
                <div class="bg-white rounded-4 p-4 shadow-sm border">
                    <h6 class="fw-bold mb-4 text-dark">สรุปผลิตภัณฑ์ของลูกค้า</h6>
                    <div class="d-flex flex-column gap-0">


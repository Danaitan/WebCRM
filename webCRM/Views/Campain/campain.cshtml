@{
    ViewData["Title"] = "สร้าง Product / Campaign - CRM";
    ViewData["HeaderTitle"] = "สร้าง Product / Campaign";
    ViewData["HeaderSubtitle"] = "สร้างและจัดการ Product / Campaign สำหรับใช้งานในระบบ CRM";
}

@section Styles {
    <link rel="stylesheet" href="~/css/campain.css?v=3" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
}

<main class="crm-main p-4">
    <div class="container-fluid max-w-custom">
        <div class="row g-4">
            <!-- Left Sidebar Column: Campaigns List -->
            <div class="col-12 col-lg-3">
                <div class="campaign-sidebar">
                    <!-- Search Input & Sort Button Side-by-Side (Prevents Overlap) -->
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <div class="search-wrapper d-flex align-items-center flex-grow-1" style="height: 42px;">
                            <span class="ps-3 text-muted"><i class="bi bi-search"></i></span>
                            <input type="text" id="campaignSearchInput" placeholder="ค้นหา Product / Campaign" class="w-100" style="border: none; outline: none; font-size: 0.9rem; padding: 0.6rem 0.8rem; background: transparent; min-width: 0;">
                        </div>
                        <div class="sort-select-container">
                            <button type="button" class="btn-sort-trigger" id="sortBtn" title="จัดเรียง">
                                <i class="bi bi-arrow-down-up"></i>
                            </button>
                            <div class="sort-dropdown-panel" id="sortDropdownPanel">
                                <div class="sort-section-title">Sort by</div>
                                <div class="sort-option" data-field="code">
                                    <i class="bi bi-check check-icon"></i>
                                    <span>product_code</span>
                                </div>
                                <div class="sort-option" data-field="name">
                                    <i class="bi bi-check check-icon"></i>
                                    <span>product_name</span>
                                </div>
                                <div class="sort-option" data-field="status">
                                    <i class="bi bi-check check-icon"></i>
                                    <span>product_status</span>
                                </div>
                                <div class="sort-option" data-field="startDate">
                                    <i class="bi bi-check check-icon"></i>
                                    <span>product_start</span>
                                </div>
                                <div class="sort-option selected" data-field="endDate">
                                    <i class="bi bi-check check-icon"></i>
                                    <span>product_end</span>
                                </div>
                                
                                <hr class="sort-divider">
                                
                                <div class="sort-section-title">Sort order</div>
                                <div class="sort-order-option selected" data-order="asc">
                                    <i class="bi bi-check check-icon"></i>
                                    <span>A to Z</span>
                                </div>
                                <div class="sort-order-option" data-order="desc">
                                    <i class="bi bi-check check-icon"></i>
                                    <span>Z to A</span>
                                </div>
                                
                                <hr class="sort-divider">
                                
                                <div class="sort-actions">
                                    <button type="button" class="btn-sort-apply" id="applySortBtn">Apply</button>
                                    <button type="button" class="btn-sort-cancel" id="cancelSortBtn">Cancel</button>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- List Header & Refresh -->
                    <div class="list-header">
                        <span>ทั้งหมด <span id="totalCampaignsCount">0</span> รายการ</span>
                    </div>
                    
                    <div class="campaign-list-container">
                        <table id="campaignsTable" class="table table-borderless" style="width:100%;">
                            <thead>
                                <tr>
                                    <th>Campaign</th>
                                    <th>Code</th>
                                    <th>Name</th>
                                    <th>Status</th>
                                    <th>Start</th>
                                    <th>End</th>
                                    <th>Remarks</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
            
            <!-- Right Main Column: Form and Configuration -->
            <div class="col-12 col-lg-9">
                <!-- Top Action Bar -->
                <div class="top-action-bar">
                    <a class="btn-action-text btn-prospect" id="prospectActionBtn" href="/ProspectSetup">
                        <i class="bi bi-people-fill"></i> Prospect
                    </a>
                    <button class="btn-action-text btn-new-campaign" id="newActionBtn">
                        <i class="bi bi-plus-lg"></i> New
                    </button>
                    <button class="btn-action-text btn-delete-campaign" id="deleteActionBtn">
                        <i class="bi bi-trash"></i> ลบ
                    </button>
                </div>
                
                <!-- Main Form Card -->
                <div class="form-card">
                    <div class="form-section-title">รายละเอียด Product</div>
                    
                    <form id="campaignForm">
                        <div class="row g-4">
                            <!-- รหัส Product / Campaign -->
                            <div class="col-md-6">
                                <label class="form-label" for="campaignCode">รหัส Product / Campaign</label>
                                <div class="input-container-icon">
                                    <input type="text" id="campaignCode" class="form-control" placeholder="กรอกรหัส Product / Campaign" style="border-radius: 8px; height: 42px;">
                                </div>
                            </div>
                            
                            <!-- ชื่อ Product / Campaign * -->
                            <div class="col-md-6">
                                <label class="form-label" for="campaignName">ชื่อ Product / Campaign <span class="required-star">*</span></label>
                                <input type="text" id="campaignName" class="form-control" placeholder="กรอกชื่อ Product / Campaign" style="border-radius: 8px; height: 42px;" required>
                            </div>
                            
                            <!-- เริ่ม * -->
                            <div class="col-md-6">
                                <label class="form-label" for="startDate">เริ่ม <span class="required-star">*</span></label>
                                <input type="date" id="startDate" class="form-control" style="border-radius: 8px; height: 42px;" required>
                            </div>
                            
                            <!-- จบ * -->
                            <div class="col-md-6">
                                <label class="form-label" for="endDate">จบ <span class="required-star">*</span></label>
                                <input type="date" id="endDate" class="form-control" style="border-radius: 8px; height: 42px;" required>
                            </div>
                            
                            <div class="col-md-6">
                                <label class="form-label">วัตถุประสงค์<span class="required-star">*</span> <i class="bi bi-info-circle text-primary" style="cursor: pointer;" title="สาขาที่มีสิทธิ์เข้าใช้งานแคมเปญนี้"></i></label>
                                
                                <div class="branch-select-container">
                                    <div class="branch-select-input-display" id="">
                                        <span class="branch-placeholder" id="">เลือกวัตถุประสงค์</span>
                                        <i class="bi bi-chevron-down branch-dropdown-arrow"></i>
                                    </div>
                                    

                                    <div class="branch-dropdown-panel" id="">
                                        <div class="branch-search-box">
                                            <input type="text" id="" placeholder="ค้นหาตถุประสงค์">
                                            <i class="bi bi-search"></i>
                                        </div>
                                        
                                        <div class="branch-list-wrapper">
                                            <div class="branch-item" id="">
                                                <input type="checkbox" id="">
                                            </div>
                                            <div id="">
                                            </div>
                                        </div>
                                    </div>

                                </div>
                            </div>
                            
                            <div class="col-md-6">
                                <label class="form-label">ใช้กับสาขา <span class="required-star">*</span> <i class="bi bi-info-circle text-primary" style="cursor: pointer;" title="สาขาที่มีสิทธิ์เข้าใช้งานแคมเปญนี้"></i></label>
                                
                                <div class="branch-select-container">
                                    <div class="branch-select-input-display" id="branchSelectDisplay">
                                        <span class="branch-placeholder" id="branchSelectPlaceholder">เลือกสาขา...</span>
                                        <i class="bi bi-chevron-down branch-dropdown-arrow"></i>
                                    </div>
                                    

                                    <div class="branch-dropdown-panel" id="branchDropdownPanel">
                                        <div class="branch-search-box">
                                            <input type="text" id="branchSearchInput" placeholder="ค้นหาสาขา...">
                                            <i class="bi bi-search"></i>
                                        </div>
                                        
                                        <div class="branch-list-wrapper">
                                            <div class="branch-item" id="selectAllBranchesItem">
                                                <input type="checkbox" id="chkSelectAllBranches">
                                                <label for="chkSelectAllBranches" class="m-0 cursor-pointer fw-semibold text-primary">เลือกทั้งหมด</label>
                                            </div>
                                            <div id="branchesListContainer">
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- หมายเหตุ -->
                            <div class="col-md-12">
                                <label class="form-label" for="modalRemarks">หมายเหตุ</label>
                                <textarea id="modalRemarks" class="form-control" rows="4" placeholder="กรอกหมายเหตุ (ถ้ามี)" maxlength="500" style="border-radius: 8px; resize: none;"></textarea>
                                <div class="char-counter" id="modalRemarksCharCounter">0 / 500</div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="chkImportExcel" name="chkImportExcel">
                                    <label class="form-check-label" for="chkImportExcel">
                                        ดึงข้อมูลจาก Excel
                                    </label>
                                </div>
                            </div>

                        </div>
                    </form>
                </div>
                
                <div class="row g-4 mb-4" id="filterSelectedRow">
                    <!-- Filter Name Panel -->
                    <div class="col-12 col-md-8">
                        <div class="sub-panel-card">
                            <div class="sub-panel-header">
                                <div class="sub-panel-title">
                                    Filter
                                </div>
                                <div class="sub-panel-meta" id="filterNameRowsCount">Rows: 0</div>
                            </div>
                            
                            <div style="font-size: 0.85rem; font-weight: 600; display: flex; border-bottom: 1px solid #e2e8f0; padding-bottom: 0.5rem; margin-bottom: 0.5rem; align-items: center;">
                                <div style="width: 8%; text-align: center;">
                                    <input type="checkbox" id="chkSelectAllFilters" style="cursor: pointer;" title="เลือกทั้งหมด">
                                </div>
                                <div style="width: 50%; color: #000000;">หัวข้อ Filter</div>
                            </div>
                            
                            <div class="empty-state-container" id="filterNameEmptyState">
                                <div class="empty-state-icon">
                                    <i class="bi bi-folder-symlink" style="font-size: 3rem;"></i>
                                </div>
                                <div class="empty-state-title">ไม่พบข้อมูล</div>
                                <div class="empty-state-desc">ยังไม่มี Filter</div>
                            </div>

                            <div id="filterNameListContainer" class="d-none" style="max-height: 250px; overflow-y: auto;">
                            </div>
                        </div>
                    </div>
                    
                    <!-- Selected Panel -->
                    <div class="col-12 col-md-4">
                        <div class="sub-panel-card">
                            <div class="sub-panel-header">
                                <div class="sub-panel-title">Filter ที่ถูกเลือก</div>
                                <div class="sub-panel-meta" id="selectedFiltersRowsCount">Rows: 0</div>
                            </div>
                            
                            <div style="font-size: 0.85rem; font-weight: 600; display: flex; border-bottom: 1px solid #e2e8f0; padding-bottom: 0.5rem; margin-bottom: 0.5rem;">
                                <div style="width: 100%; color: #64748b;">ชื่อ Filter</div>
                            </div>
                            
                            <div class="empty-state-container" id="selectedFiltersEmptyState">
                                <div class="empty-state-icon">
                                    <i class="bi bi-file-earmark-text" style="font-size: 3rem;"></i>
                                </div>
                                <div class="empty-state-title">ไม่พบข้อมูล</div>
                                <div class="empty-state-desc">ยังไม่มีข้อมูลที่เลือก</div>
                            </div>

                            <div id="selectedFiltersListContainer" class="d-none" style="max-height: 250px; overflow-y: auto;">
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Bottom Action Buttons -->
                <div class="bottom-actions-row">
                    <button type="button" class="btn-cancel" id="cancelFormBtn">ยกเลิก</button>
                    <button type="button" class="btn-submit" id="submitFormBtn">บันทึก</button>
                </div>
            </div>
            
        </div>
    </div>

    <!-- Create Campaign Modal -->
    <div class="modal fade" id="createCampaignModal" tabindex="-1" aria-labelledby="createCampaignModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content" style="border-radius: 16px;">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title form-section-title" id="createCampaignModalLabel" style="margin-bottom: 0;">สร้าง Product</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <form id="modalCampaignForm">
                        <div class="row g-4">
                            <!-- รหัส Product / Campaign -->
                            <div class="col-md-6">
                                <label class="form-label" for="modalCampaignCode">รหัส Product / Campaign</label>
                                <div class="input-container-icon">
                                    <input type="text" id="modalCampaignCode" class="form-control" placeholder="กรอกรหัส Product / Campaign" style="border-radius: 8px; height: 42px;">
                                </div>
                            </div>
                            
                            <!-- ชื่อ Product / Campaign * -->
                            <div class="col-md-6">
                                <label class="form-label" for="modalCampaignName">ชื่อ Product / Campaign <span class="required-star">*</span></label>
                                <input type="text" id="modalCampaignName" class="form-control" placeholder="กรอกชื่อ Product / Campaign" style="border-radius: 8px; height: 42px;" required>
                            </div>
                            
                            <!-- เริ่ม * -->
                            <div class="col-md-6">
                                <label class="form-label" for="modalStartDate">เริ่ม <span class="required-star">*</span></label>
                                <input type="date" id="modalStartDate" class="form-control" style="border-radius: 8px; height: 42px;" required>
                            </div>
                            
                            <!-- จบ * -->
                            <div class="col-md-6">
                                <label class="form-label" for="modalEndDate">จบ <span class="required-star">*</span></label>
                                <input type="date" id="modalEndDate" class="form-control" style="border-radius: 8px; height: 42px;" required>
                            </div>
                            
                            <div class="col-md-6">
                                <label class="form-label">วัตถุประสงค์ <span class="required-star">*</span> <i class="bi bi-info-circle text-primary" style="cursor: pointer;" title="สาขาที่มีสิทธิ์เข้าใช้งานแคมเปญนี้"></i></label>
                                
                                <div class="branch-select-container">
                                    <div class="branch-select-input-display" id="branchSelectDisplay">
                                        <span class="branch-placeholder" id="branchSelectPlaceholder">เลือกวัตถุประสงค์</span>
                                        <i class="bi bi-chevron-down branch-dropdown-arrow"></i>
                                    </div>
                                    

                                    <div class="branch-dropdown-panel" id="branchDropdownPanel">
                                        <div class="branch-search-box">
                                            <input type="text" id="branchSearchInput" placeholder="ค้นหาสาขา...">
                                            <i class="bi bi-search"></i>
                                        </div>
                                        
                                        <div class="branch-list-wrapper">
                                            <div class="branch-item" id="selectAllBranchesItem">
                                                <input type="checkbox" id="chkSelectAllBranches">
                                                <label for="chkSelectAllBranches" class="m-0 cursor-pointer fw-semibold text-primary">เลือกทั้งหมด</label>
                                            </div>
                                            <div id="branchesListContainer">
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- ใช้กับสาขา * -->
                            <div class="col-md-6">
                                <label class="form-label">ใช้กับสาขา <span class="required-star">*</span></label>
                                
                                <div class="branch-select-container">
                                    <div class="branch-select-input-display" id="modalBranchSelectDisplay">
                                        <span class="branch-placeholder" id="modalBranchSelectPlaceholder">เลือกสาขา...</span>
                                        <i class="bi bi-chevron-down branch-dropdown-arrow"></i>
                                    </div>
                                    
                                    <div class="branch-dropdown-panel" id="modalBranchDropdownPanel">
                                        <div class="branch-search-box">
                                            <input type="text" id="modalBranchSearchInput" placeholder="ค้นหาสาขา...">
                                            <i class="bi bi-search"></i>
                                        </div>
                                        
                                        <div class="branch-list-wrapper">
                                            <div class="branch-item" id="modalSelectAllBranchesItem">
                                                <input type="checkbox" id="modalChkSelectAllBranches">
                                                <label for="modalChkSelectAllBranches" class="m-0 cursor-pointer fw-semibold text-primary">เลือกทั้งหมด</label>
                                            </div>
                                            <div id="modalBranchesListContainer">
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- หมายเหตุ -->
                            <div class="col-md-12">
                                <label class="form-label" for="modalRemarks">หมายเหตุ</label>
                                <textarea id="modalRemarks" class="form-control" rows="4" placeholder="กรอกหมายเหตุ (ถ้ามี)" maxlength="500" style="border-radius: 8px; resize: none;"></textarea>
                                <div class="char-counter" id="modalRemarksCharCounter">0 / 500</div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="chkImportExcel" name="chkImportExcel">
                                    <label class="form-check-label" for="chkImportExcel">
                                        ดึงข้อมูลจาก Excel
                                    </label>
                                </div>
                            </div>
                            
                        </div>
                    </form>
                </div>
                <div class="modal-footer border-0 pt-0 px-4 pb-4">
                    <button type="button" class="btn-cancel" data-bs-dismiss="modal">ยกเลิก</button>
                    <button type="button" class="btn-submit" id="modalSubmitBtn">บันทึกเพื่อสร้างใหม่</button>
                </div>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <partial name="~/Views/Component/NotiModal.cshtml" />
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script>
        window.CURRENT_COMPANY = '@(Context.Session.GetString("company") ?? "MICRO")';
        window.CURRENT_USER_ID = '@(Context.Session.GetString("personalId") ?? "system")';
    </script>
    <script src="~/Views/Campain/campaign.js" asp-append-version="true"></script>
}
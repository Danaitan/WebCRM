@{
    ViewData["Title"] = "Prospect Assign";
    ViewData["HeaderTitle"] = "Prospect Assign";
    ViewData["HeaderSubtitle"] = "กำหนดผู้รับผิดชอบลูกค้า Propect ตาม Campaign";
}

@section Styles {
    <link rel="stylesheet" href="~/css/prospectAssign.css" asp-append-version="true" />
}
<div class="container-fluid p-4 h-100 d-flex flex-column" style="gap: 20px;">
    
    <!-- Top Section -->
    <div class="row g-4">
        
        <!-- Left Side: Filter + Summary -->
        <div class="col-xl-8 col-lg-7 d-flex flex-column" style="gap: 20px;">
            
            <!-- Filter Card -->
            <div class="card-custom p-4">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label-custom">Product/Campaign Code</label>
                        <input type="text" id="filterCampaignCode" class="form-control form-control-custom" placeholder="เช่น CAM-202505">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label-custom">Product/Campaign Name</label>
                        <input type="text" id="filterCampaignName" class="form-control form-control-custom" placeholder="เช่น สินเชื่อรถยนต์ พ.ศ. 2568">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label-custom">วันที่เริ่มต้น</label>
                        <div class="position-relative">
                            <i class="bi bi-calendar position-absolute" style="left: 12px; top: 50%; transform: translateY(-50%); color: var(--text-gray);"></i>
                            <input type="text" id="filterStartDate" class="form-control form-control-custom" value="" style="padding-left: 35px;">
                        </div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label-custom">วันที่สิ้นสุด</label>
                        <div class="position-relative">
                            <i class="bi bi-calendar position-absolute" style="left: 12px; top: 50%; transform: translateY(-50%); color: var(--text-gray);"></i>
                            <input type="text" id="filterEndDate" class="form-control form-control-custom" value="" style="padding-left: 35px;">
                        </div>
                    </div>
                    
                    <div class="col-md-5">
                        <label class="form-label-custom">หมายเหตุ</label>
                        <input type="text" id="filterRemark" class="form-control form-control-custom" placeholder="ระบุหมายเหตุ (ถ้ามี)">
                    </div>
                    <div class="col-md-7">
                        <label class="form-label-custom">เลือกสาขา / Branch (เลือกได้หลายสาขา)</label>
                        <div class="form-control form-control-custom d-flex align-items-center flex-wrap gap-2 py-1" style="min-height: 38px; height: auto;">
                            <span class="branch-tag">00 สำนักงานใหญ่ <i class="bi bi-x"></i></span>
                            <span class="branch-tag">06 ชลบุรี <i class="bi bi-x"></i></span>
                            <span class="branch-tag">12 สุราษฎร์ธานี <i class="bi bi-x"></i></span>
                            <div class="d-flex align-items-center flex-grow-1 ms-1">
                                <i class="bi bi-search" style="font-size: 0.8rem; color: #94a3b8;"></i>
                                <input type="text" class="border-0 shadow-none bg-transparent" placeholder="ค้นหาสาขา" style="outline: none; font-size: 0.85rem; width: 80px; margin-left: 5px;">
                            </div>
                            <i class="bi bi-chevron-down ms-auto" style="font-size: 0.8rem; color: #94a3b8;"></i>
                        </div>
                    </div>
                    
                    <div class="col-12 mt-4 d-flex gap-2">
                        @* <button class="btn-primary-custom d-flex align-items-center gap-2">
                            <i class="bi bi-search"></i> Load Customer
                        </button> *@
                        <button class="btn-outline-custom d-flex align-items-center gap-2">
                            <i class="bi bi-floppy"></i> Save Batch
                        </button>
                        <button class="btn-outline-custom d-flex align-items-center gap-2">
                            <i class="bi bi-send"></i> Send Approve
                        </button>
                    </div>
                </div>
            </div>
            

                                <span class="fw-medium text-dark">MIB</span>
                            </div>
                            <span class="text-muted" id="summary-mib-count">0 กรมธรรม์</span>
                        </div>

                    </div>
                </div>
            </div>

            <!-- Right Column -->
            <div class="col-12 col-lg-7">

        function switchTab(tabId) {
            document.querySelectorAll('.pc-tab-btn').forEach(btn => btn.classList.remove('active'));
            document.getElementById('tabBtn' + tabId.replace('tab', '')).classList.add('active');
            document.querySelectorAll('.pc-tab-content').forEach(c => c.classList.remove('active'));
            document.getElementById(tabId).classList.add('active');
        }
    </script>

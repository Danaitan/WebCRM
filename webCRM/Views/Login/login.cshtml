@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>เข้าสู่ระบบ - CRM</title>
    <!-- Use Google Fonts (Kanit) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="/css/login.css" rel="stylesheet" />
</head>
<body>
    <div class="login-container">
        <!-- --- Left Panel (Light Blue Background) --- -->
        <div class="left-panel">
            @* <div class="logo-container">
                <div class="logo-icon">
                    <svg width="42" height="42" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M6 30V10L20 22L34 10V30" stroke="#004085" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M20 22L34 10" stroke="#007bff" stroke-width="4" stroke-linecap="round"/>
                    </svg>
                </div>
                <div class="logo-text">
                    <span class="logo-text-micro">MICRO</span>
                    <span class="logo-text-leasing">LEASING</span>
                </div>
            </div> *@
            
            <div class="copyright">
                &copy; 2024 Micro Leasing Public Company Limited. All rights reserved.
            </div>
        </div>
        
        <!-- --- Right Panel (Login Form) --- -->
        <div class="right-panel">
            <div class="lang-selector">
                <svg class="globe-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="2" y1="12" x2="22" y2="12"></line>
                    <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                </svg>
                ไทย
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left:8px;">
                    <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
            </div>
            
            <div class="login-form-container">
                <div class="login-header">
                    <h2>เข้าสู่ระบบ</h2>
                    <p>กรุณาเข้าสู่ระบบเพื่อใช้งาน CRM</p>
                </div>
                
                <form onsubmit="event.preventDefault(); login();">
                    <div class="form-group">
                        <label for="username">รหัสพนักงาน</label>
                        <div class="input-group">
                            <svg class="icon-left" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                <circle cx="12" cy="7" r="4"></circle>
                            </svg>
                            <input type="text" id="username" name="username" placeholder="กรอกรหัสพนักงานหรืออีเมล" required>
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label for="password">รหัสผ่าน</label>
                        <div class="input-group">
                            <svg class="icon-left" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                                <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                            </svg>
                            <input type="password" id="password" name="password" placeholder="กรอกรหัสผ่าน" required>
                            <svg class="icon-right" id="togglePassword" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                <circle cx="12" cy="12" r="3"></circle>
                            </svg>
                        </div>
                    </div>
                    
                    @* <div class="form-options">
                        <label class="checkbox-container">
                            <input type="checkbox" id="remember" name="remember" checked>
                            <span>จดจำการเข้าสู่ระบบ</span>
                        </label>
                    </div> *@
                    
                    <p id="errorMessage" style="color: #dc3545; display: none; margin-bottom: 15px; font-size: 14px; text-align: center;">รหัสพนักงานหรือรหัสผ่านไม่ถูกต้อง</p>
                    <button type="submit" class="btn-submit">เข้าสู่ระบบ</button>
                </form>
            </div>
            
            <div class="support-footer">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 18v-6a9 9 0 0 1 18 0v6"></path>
                    <path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"></path>
                </svg>
                พบปัญหาในการใช้งาน ติดต่อ IT Support : 02-123-4567 ต่อ 1234
            </div>
        </div>
    </div>

    <script>
        // Toggle Password Visibility
        const togglePassword = document.querySelector('#togglePassword');
        const password = document.querySelector('#password');

        togglePassword.addEventListener('click', function () {
            const type = password.getAttribute('type') === 'password' ? 'text' : 'password';
            password.setAttribute('type', type);
            
            if (type === 'text') {
                // Change icon to eye-off when password is visible
                togglePassword.innerHTML = '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line>';
            } else {
                // Change back to eye icon when password is hidden
                togglePassword.innerHTML = '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle>';
            }
        });
    
    async function login (){
        var username = document.getElementById("username").value;
        var password = document.getElementById("password").value;
        var rememberElement = document.getElementById("remember");
        var remember = rememberElement ? rememberElement.checked : false;
        var errorMessage = document.getElementById("errorMessage");

        errorMessage.style.display = "none";

        const response = await fetch(`/Login/GetProfile?username=${username}&password=${password}`);
        if (response.ok) {
            if (remember) {
                localStorage.setItem("crm_username", username);
                localStorage.setItem("crm_password", password);
            } else {
                localStorage.removeItem("crm_username");
                localStorage.removeItem("crm_password");
            }
            window.location.href = "/Home/Index";
        } else {
            try {
                const errData = await response.json();
                if (errData && errData.message) {
                    errorMessage.innerText = errData.message;
                } else {
                    errorMessage.innerText = "รหัสพนักงานหรือรหัสผ่านไม่ถูกต้อง";
                }
            } catch (e) {
                errorMessage.innerText = "รหัสพนักงานหรือรหัสผ่านไม่ถูกต้อง";
            }
            errorMessage.style.display = "block";
        }
    }

    // Load saved credentials on page load
    document.addEventListener("DOMContentLoaded", function() {
        var savedUsername = localStorage.getItem("crm_username");
        var savedPassword = localStorage.getItem("crm_password");
        var rememberElement = document.getElementById("remember");
        
        if (savedUsername && savedPassword) {
            document.getElementById("username").value = savedUsername;
            document.getElementById("password").value = savedPassword;
            if (rememberElement) rememberElement.checked = true;
        } else {
            if (rememberElement) rememberElement.checked = false;
        }
    });
    
    </script>
</body>
</html>
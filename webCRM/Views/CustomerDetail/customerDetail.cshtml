                                <input type="text" class="form-control" placeholder="กรุณากรอกชื่อ-นามสกุล">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-medium small">E-Mail (ของผู้ให้ข้อมูล)</label>
                                <input type="email" class="form-control" placeholder="ตัวอย่าง: example@email.com">
                            </div>
                        </div>

                        <div class="row g-3 mb-3">

                    </div>

                    <form>
                        <div class="row g-3 mb-3">
                            <div class="col-md-4">
                                <label class="form-label fw-medium small">หัวข้อ <span class="text-danger">*</span></label>
                                <select class="form-select text-muted" aria-label="Topic">
                                    <option selected>เลือกหัวข้อ</option>
                                    <option value="1">เสนอแนะ</option>
                                    <option value="2">ร้องเรียน</option>
                                    <option value="3">สนใจผลิตภัณฑ์</option>
                                </select>
                            </div>
                            <div class="col-md-4">

@{
    ViewData["Title"] = "Prospect Setup";
    ViewData["HeaderTitle"] = "Prospect Setup";
    ViewData["HeaderSubtitle"] = "จัดการและตั้งค่าชุดข้อมูลลูกค้าเป้าหมาย (Prospect)";
}

@section Styles {
    <link rel="stylesheet" href="~/css/prospectSetup.css" asp-append-version="true" />
}
<!-- Main Layout -->
<div class="prospect-layout">
    
    <!-- Left Panel -->
    <div class="panel-left">
        <div class="d-flex gap-2 mb-3">
            <div class="search-box">
                <i class="bi bi-search"></i>
                <input type="text" class="form-control form-control-custom w-100" placeholder="ค้นหา Batch / Product">
            </div>
        </div>
        
        <div class="d-flex justify-content-between align-items-center mb-3">
            <span class="text-dark fw-medium" id="batchFoundCount" style="font-size: 0.9rem;">พบ 0 รายการ</span>
            <i class="bi bi-arrow-down-up text-secondary" style="cursor:pointer; font-size: 0.9rem;"></i>
        </div>
        
        <div class="flex-grow-1 overflow-auto pe-1" id="dataTable">
        </div>
        
        <div class="d-flex justify-content-between align-items-center mt-3 pt-2 border-top">
            <span class="text-muted" style="font-size: 0.75rem;" id="batchListText">แสดง 1 - 5 จาก 12 รายการ</span>
            <ul class="pagination pagination-sm pagination-custom mb-0" id="batchPagination">
            </ul>
        </div>
    </div>

    <div class="panel-main">

        <div class="card-custom mb-4">
            <div class="card-header-custom">
                <h3 class="card-title-custom">
                    <i class="bi bi-funnel-fill text-primary"></i> เงื่อนไขการคัดเลือกลูกค้าเป้าหมาย
                </h3>
            </div>
            <div class="card-body-custom">
                <div class="row g-3">
                    <div class="col-xxl-4 col-xl-6 col-md-6">
                        <label class="form-label-custom">ประเภทลูกค้า</label>
                        <select class="form-select form-select-custom" id="filterCustType">
                            <option value="">ทุกประเภท</option>
                            <option value="บุคคลธรรมดา">บุคคลธรรมดา</option>
                            <option value="นิติบุคคล">นิติบุคคล</option>
                        </select>
                    </div>
                    <div class="col-xxl-4 col-xl-6 col-md-6">
                        <label class="form-label-custom">เพศ</label>
                        <select class="form-select form-select-custom" id="filterGender">
                            <option value="">ทุกเพศ</option>
                            <option value="ชาย">ชาย</option>
                            <option value="หญิง">หญิง</option>
                        </select>
                    </div>
                    <div class="col-xxl-4 col-xl-6 col-md-6">
                        <label class="form-label-custom">ช่วงอายุ</label>
                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            <input type="number" class="form-control form-control-custom text-center" value="25" style="width: 70px;" id="filterAgeMin">
                            <span class="text-muted" style="font-size: 0.85rem;">ถึง</span>
                            <input type="number" class="form-control form-control-custom text-center" value="60" style="width: 70px;" id="filterAgeMax">
                            <span class="text-muted ms-1" style="font-size: 0.85rem;">ปี</span>
                        </div>
                    </div>
                    
                    <div class="col-xxl-4 col-xl-6 col-md-6">
                        <label class="form-label-custom">อาชีพ</label>
                        <select class="form-select form-select-custom" id="filterJob">
                            <option value="">ทุกอาชีพ</option>
                            <option value="พนักงานบริษัท">พนักงานบริษัท</option>
                            <option value="ธุรกิจส่วนตัว">ธุรกิจส่วนตัว</option>
                            <option value="เจ้าของกิจการ">เจ้าของกิจการ</option>
                            <option value="ฟรีแลนซ์">ฟรีแลนซ์</option>
                        </select>
                    </div>
                    <div class="col-xxl-8 col-xl-12 col-md-12">
                        <label class="form-label-custom">สถานะลูกค้า</label>
                        <select class="form-select form-select-custom" id="filterStatus">
                            <option value="">ทุกสถานะ</option>
                            <option value="รอการอนุมัติ">รอการอนุมัติ</option>
                            <option value="อนุมัติแล้ว">อนุมัติแล้ว</option>
                            <option value="ไม่อนุมัติ">ไม่อนุมัติ</option>
                        </select>
                    </div>
                    
                    <div class="col-xxl-4 col-xl-6 col-md-6">
                        <label class="form-label-custom">พื้นที่ / สาขา</label>
                        <select class="form-select form-select-custom" id="filterBranch">
                            <option value="">ทุกสาขา</option>
                            <option value="สาขานครราชสีมา">สาขานครราชสีมา</option>
                            <option value="สาขาขอนแก่น">สาขาขอนแก่น</option>
                            <option value="สาขาอุดรธานี">สาขาอุดรธานี</option>
                            <option value="สาขาเชียงใหม่">สาขาเชียงใหม่</option>
                            <option value="สาขาภูเก็ต">สาขาภูเก็ต</option>
                        </select>
                    </div>
                    <div class="col-xxl-8 col-xl-12 col-md-12">
                        <label class="form-label-custom">ช่วงวันที่สร้างข้อมูล</label>
                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            <div class="position-relative" style="width: 150px;">
                                <input type="date" class="form-control form-control-custom" value="2024-05-01" id="filterDateStart">
                            </div>
                            <span class="text-muted" style="font-size: 0.85rem;">ถึง</span>
                            <div class="position-relative" style="width: 150px;">
                                <input type="date" class="form-control form-control-custom" value="2024-05-12" id="filterDateEnd">
                            </div>
                        </div>
                    </div>
                    
                    <div class="col-12 mt-4 d-flex gap-2 flex-wrap">
                        @* <button class="btn btn-primary px-4 py-2" style="border-radius: 8px; font-size: 0.9rem; font-weight: 500;" id="btnApplyFilters">
                            <i class="bi bi-search me-1"></i> ค้นหา
                        </button> *@
                        <button class="btn btn-outline-secondary px-4 py-2" style="border-radius: 8px; font-size: 0.9rem; font-weight: 500;" id="btnClearFilters">
                            <i class="bi bi-arrow-counterclockwise me-1"></i> ล้างเงื่อนไข
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="card-custom mb-0">

                <div class="card-header-custom border-0 pb-0">

                <div class="d-flex gap-2 flex-shrink-0">
                    <button class="btn btn-outline-primary btn-sm px-3 d-flex align-items-center gap-1" style="border-radius: 6px; font-weight: 500; font-size: 0.85rem; white-space: nowrap;" id="btnExportExcel">
                        <i class="bi bi-download"></i> ส่งออก Excel
                    </button>
                    <button class="btn btn-light btn-sm text-secondary border" style="border-radius: 6px;">
                        <i class="bi bi-gear"></i>
                    </button>
                </div>

            </div>

            <div class="card-body-custom pt-3">
                    <div class="fw-medium mb-2" style="font-size: 0.9rem;" id="totalFoundText">รายการลูกค้า (พบ <span id="totalFound">0</span> รายการ)</div>
                    <div class="table-responsive border rounded-3">
                        <table class="table table-hover table-custom mb-0" 
                        id="batchListContainer"
                        >
                            <thead>
                                <tr>
                                    <th style="width: 40px; text-align: center;">
                                        <div class="form-check d-flex justify-content-center m-0">
                                            <input class="form-check-input" type="checkbox" id="checkAll">
                                        </div>
                                    </th>
                                    <th>บริษัท / รหัส Campaign</th>
                                    <th>ชื่อ Campaign</th>
                                    <th>รหัส Product</th>
                                    <th>ช่วงเวลา</th>
                                    <th>สถานะ</th>
                                </tr>
                            </thead>
                            <tbody id="dataTableBody">
                                <!-- Rendered by DataTables -->
                            </tbody>
                        </table>
                    </div>
                    
                    <div class="d-flex justify-content-between align-items-center mt-3 flex-wrap gap-3">
                        <div class="d-flex align-items-center gap-2">
                            <span class="text-muted" style="font-size: 0.85rem;">แสดง</span>
                            <select class="form-select form-select-sm" id="rowsPerPage" style="width: 70px; border-radius: 6px;">
                                <option value="2">2</option>
                                <option value="5">5</option>
                                <option value="10" selected>10</option>
                                <option value="20">20</option>
                                <option value="50">50</option>
                            </select>
                            <span class="text-muted" style="font-size: 0.85rem;">รายการ</span>
                        </div>
                        
                        <div class="d-flex align-items-center gap-3 flex-wrap">
                            <ul class="pagination pagination-sm pagination-custom mb-0 flex-wrap" id="tablePagination">
                            </ul>
                            <div class="d-flex align-items-center gap-2">
                                <span class="text-muted" style="font-size: 0.85rem;">ไปที่</span>
                                <input type="text" class="form-control form-control-sm text-center" id="goToPageInput" value="1" style="width: 40px; border-radius: 6px;">
                                <span class="text-muted" style="font-size: 0.85rem;">หน้า</span>
                            </div>
                        </div>
                    </div>
            </div>

        </div> 

    </div>

    <div class="panel-right">
            
        <!-- Action Buttons -->
        <div>
            <div class="d-flex align-items-center gap-3 mb-4">
                <label class="form-label-custom mb-0 w-auto text-nowrap">เลือกสถานะ</label>
                <select class="form-select form-select-custom">
                    <option>รอการอนุมัติ</option>
                </select>
            </div>
            
            <button class="action-btn btn-primary-green">
                <i class="bi bi-file-earmark-text"></i>
                <div>
                    <span class="action-btn-title">บันทึกชุดข้อมูล</span>
                    <span class="action-btn-sub">บันทึกชุดข้อมูลนี้</span>
                </div>
            </button>
            
            <button class="action-btn btn-primary-purple">
                <i class="bi bi-send"></i>
                <div>
                    <span class="action-btn-title">ส่งอนุมัติ</span>
                    <span class="action-btn-sub">ส่งชุดข้อมูลเพื่อขออนุมัติ</span>
                </div>
            </button>
        </div>
        
        <!-- Selected Items -->
        <div class="mt-4 pt-3 border-top">
            <div class="selected-list-header">
                <span class="selected-list-title" id="selectedCountText">รายการที่เลือก (0 รายการ)</span>
                @* <button class="btn-clear" id="btnClearSelection">
                    <i class="bi bi-trash3"></i> ล้างรายการ
                </button> *@
            </div>
            
            <div class="table-responsive rounded border mb-3">
                <table class="table table-borderless selected-table mb-0">
                    <thead>
                        <tr>
                            <th style="width: 40px;" class="text-center">ลำดับ</th>
                            <th>ชื่อลูกค้า</th>
                            <th>เลขที่สัญญา</th>
                            <th style="width: 30px;"></th>
                        </tr>
                    </thead>
                    <tbody id="selectedTableBody">
                    </tbody>
                </table>
            </div>
            
            <div class="text-muted" style="font-size: 0.8rem;" id="selectedTotalText">
                รวมทั้งหมด 0 รายการ
            </div>
        </div>
            
    </div>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/xlsx-js-style@1.2.0/dist/xlsx.bundle.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="~/Views/ProspectSetup/prospectSetup.js" asp-append-version="true"></script>
}

@{
    ViewData["Title"] = "สร้าง Product / Campaign - CRM";
    ViewData["HeaderTitle"] = "สร้าง Product / Campaign";
    ViewData["HeaderSubtitle"] = "สร้างและจัดการ Product / Campaign สำหรับใช้งานในระบบ CRM";
}

@section Styles {
    <link rel="stylesheet" href="~/css/campain.css?v=3" />
}

<main class="crm-main p-4">
    <div class="container-fluid max-w-custom">
        <div class="row g-4">
            <!-- Left Sidebar Column: Campaigns List -->
            <div class="col-12 col-lg-3">
                <div class="campaign-sidebar">
                    <!-- Search Input & Sort Button Side-by-Side (Prevents Overlap) -->
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <div class="search-wrapper d-flex align-items-center flex-grow-1" style="height: 42px;">
                            <span class="ps-3 text-muted"><i class="bi bi-search"></i></span>
                            <input type="text" id="campaignSearchInput" placeholder="ค้นหา Product / Campaign" class="w-100" style="border: none; outline: none; font-size: 0.9rem; padding: 0.6rem 0.8rem; background: transparent; min-width: 0;">
                        </div>
                        <div class="sort-select-container">
                            <button type="button" class="btn-sort-trigger" id="sortBtn" title="จัดเรียง">
                                <i class="bi bi-arrow-down-up"></i>
                            </button>
                            <div class="sort-dropdown-panel" id="sortDropdownPanel">
                                <div class="sort-section-title">Sort by</div>
                                <div class="sort-option" data-field="code">
                                    <i class="bi bi-check check-icon"></i>
                                    <span>product_code</span>
                                </div>
                                <div class="sort-option" data-field="name">
                                    <i class="bi bi-check check-icon"></i>
                                    <span>product_name</span>
                                </div>
                                <div class="sort-option" data-field="status">
                                    <i class="bi bi-check check-icon"></i>
                                    <span>product_status</span>
                                </div>
                                <div class="sort-option" data-field="startDate">
                                    <i class="bi bi-check check-icon"></i>
                                    <span>product_start</span>
                                </div>
                                <div class="sort-option selected" data-field="endDate">
                                    <i class="bi bi-check check-icon"></i>
                                    <span>product_end</span>
                                </div>
                                
                                <hr class="sort-divider">
                                
                                <div class="sort-section-title">Sort order</div>
                                <div class="sort-order-option selected" data-order="asc">
                                    <i class="bi bi-check check-icon"></i>
                                    <span>A to Z</span>
                                </div>
                                <div class="sort-order-option" data-order="desc">
                                    <i class="bi bi-check check-icon"></i>
                                    <span>Z to A</span>
                                </div>
                                
                                <hr class="sort-divider">
                                
                                <div class="sort-actions">
                                    <button type="button" class="btn-sort-apply" id="applySortBtn">Apply</button>
                                    <button type="button" class="btn-sort-cancel" id="cancelSortBtn">Cancel</button>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- List Header & Refresh -->
                    <div class="list-header">
                        <span>ทั้งหมด <span id="totalCampaignsCount">0</span> รายการ</span>
                        @* <button class="btn-refresh-list" id="refreshCampaignsListBtn" title="รีเฟรชข้อมูล">
                            <i class="bi bi-arrow-clockwise"></i>
                        </button> *@
                    </div>
                    
                    <!-- Scrollable Cards Container -->
                    <div class="campaign-list-container" id="campaignsContainer">
                        <!-- Campaign Cards will render here dynamically -->
                    </div>
                    
                    <!-- Pagination Controls -->
                    <div class="campaign-pagination" id="campaignPagination">
                        <!-- Pagination buttons will render here dynamically -->
                    </div>
                </div>
            </div>
            
            <!-- Right Main Column: Form and Configuration -->
            <div class="col-12 col-lg-9">
                <!-- Top Action Bar -->
                <div class="top-action-bar">
                    <a class="btn-action-text btn-prospect" id="prospectActionBtn" href="/ProspectSetup">
                        <i class="bi bi-people-fill"></i> Prospect
                    </a>
                    <button class="btn-action-text btn-new-campaign" id="newActionBtn">
                        <i class="bi bi-plus-lg"></i> New
                    </button>
                    <button class="btn-action-text btn-delete-campaign" id="deleteActionBtn">
                        <i class="bi bi-trash"></i> ลบ
                    </button>
                </div>
                
                <!-- Main Form Card -->
                <div class="form-card">
                    <div class="form-section-title">รายละเอียด Product</div>
                    
                    <form id="campaignForm">
                        <div class="row g-4">
                            <!-- รหัส Product / Campaign -->
                            <div class="col-md-6">
                                <label class="form-label" for="campaignCode">รหัส Product / Campaign</label>
                                <div class="input-container-icon">
                                    <input type="text" id="campaignCode" class="form-control" placeholder="กรอกรหัส Product / Campaign" style="border-radius: 8px; height: 42px;">
                                    <button type="button" class="input-icon-right" id="syncCampaignCodeBtn" title="สุ่มรหัส">
                                        <i class="bi bi-arrow-clockwise"></i>
                                    </button>
                                </div>
                            </div>
                            
                            <!-- ชื่อ Product / Campaign * -->
                            <div class="col-md-6">
                                <label class="form-label" for="campaignName">ชื่อ Product / Campaign <span class="required-star">*</span></label>
                                <input type="text" id="campaignName" class="form-control" placeholder="กรอกชื่อ Product / Campaign" style="border-radius: 8px; height: 42px;" required>
                            </div>
                            
                            <!-- เริ่ม * -->
                            <div class="col-md-6">
                                <label class="form-label" for="startDate">เริ่ม <span class="required-star">*</span></label>
                                <input type="date" id="startDate" class="form-control" style="border-radius: 8px; height: 42px;" required>
                            </div>
                            
                            <!-- จบ * -->
                            <div class="col-md-6">
                                <label class="form-label" for="endDate">จบ <span class="required-star">*</span></label>
                                <input type="date" id="endDate" class="form-control" style="border-radius: 8px; height: 42px;" required>
                            </div>
                            
                            <!-- หมายเหตุ -->
                            <div class="col-md-6">
                                <label class="form-label" for="remarks">หมายเหตุ</label>
                                <textarea id="remarks" class="form-control" rows="4" placeholder="กรอกหมายเหตุ (ถ้ามี)" maxlength="500" style="border-radius: 8px; resize: none;"></textarea>
                                <div class="char-counter" id="remarksCharCounter">0 / 500</div>
                            </div>
                            
                            <!-- ใช้กับสาขา * -->
                            <div class="col-md-6">
                                <label class="form-label">ใช้กับสาขา <span class="required-star">*</span> <i class="bi bi-info-circle text-primary" style="cursor: pointer;" title="สาขาที่มีสิทธิ์เข้าใช้งานแคมเปญนี้"></i></label>
                                
                                <div class="branch-select-container">
                                    <div class="branch-select-input-display" id="branchSelectDisplay">
                                        <span class="branch-placeholder" id="branchSelectPlaceholder">เลือกสาขา...</span>
                                        <!-- Selected branch tags go here dynamically -->
                                        <i class="bi bi-chevron-down branch-dropdown-arrow"></i>
                                    </div>
                                    
                                    <!-- Dropdown Overlay -->
                                    <div class="branch-dropdown-panel" id="branchDropdownPanel">
                                        <div class="branch-search-box">
                                            <input type="text" id="branchSearchInput" placeholder="ค้นหาสาขา...">
                                            <i class="bi bi-search"></i>
                                        </div>
                                        
                                        <div class="branch-list-wrapper">
                                            <!-- Select All Item -->
                                            <div class="branch-item" id="selectAllBranchesItem">
                                                <input type="checkbox" id="chkSelectAllBranches">
                                                <label for="chkSelectAllBranches" class="m-0 cursor-pointer fw-semibold text-primary">เลือกทั้งหมด</label>
                                            </div>
                                            <!-- Branches render here -->
                                            <div id="branchesListContainer">
                                                <!-- Dynamic checkboxes render here -->
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
                
                <!-- Bottom Grids: Filter Name & Selected -->
                <div class="row g-4 mb-4">
                    <!-- Filter Name Panel -->
                    <div class="col-12 col-md-8">
                        <div class="sub-panel-card">
                            <div class="sub-panel-header">
                                <div class="sub-panel-title">
                                    Filter Name
                                    @* <button class="btn-refresh-list" id="refreshFiltersBtn" title="รีเฟรชตัวกรอง">
                                        <i class="bi bi-arrow-clockwise"></i>
                                    </button> *@
                                </div>
                                <div class="sub-panel-meta">Rows: 0</div>
                            </div>
                            
                            <div style="font-size: 0.85rem; font-weight: 600; display: flex; border-bottom: 1px solid #e2e8f0; padding-bottom: 0.5rem; margin-bottom: 0.5rem;">
                                <div style="width: 50%; color: #64748b;">Filter Name</div>
                                <div style="width: 50%; color: #64748b;">อธิบาย</div>
                            </div>
                            
                            <div class="empty-state-container">
                                <div class="empty-state-icon">
                                    <i class="bi bi-folder-symlink" style="font-size: 3rem;"></i>
                                </div>
                                <div class="empty-state-title">ไม่พบข้อมูล</div>
                                <div class="empty-state-desc">ยังไม่มี Filter Name</div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Selected Panel -->
                    <div class="col-12 col-md-4">
                        <div class="sub-panel-card">
                            <div class="sub-panel-header">
                                <div class="sub-panel-title">Selected</div>
                            </div>
                            
                            <div style="font-size: 0.85rem; font-weight: 600; display: flex; border-bottom: 1px solid #e2e8f0; padding-bottom: 0.5rem; margin-bottom: 0.5rem;">
                                <div style="width: 60%; color: #64748b;">Filter Name</div>
                                <div style="width: 40%; color: #64748b;">Company</div>
                            </div>
                            
                            <div class="empty-state-container">
                                <div class="empty-state-icon">
                                    <i class="bi bi-file-earmark-text" style="font-size: 3rem;"></i>
                                </div>
                                <div class="empty-state-title">ไม่พบข้อมูล</div>
                                <div class="empty-state-desc">ยังไม่มีข้อมูลที่เลือก</div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Bottom Action Buttons -->
                <div class="bottom-actions-row">
                    <button type="button" class="btn-cancel" id="cancelFormBtn">ยกเลิก</button>
                    <button type="button" class="btn-submit" id="submitFormBtn">บันทึก</button>
                </div>
            </div>
            
        </div>
    </div>

    <!-- Create Campaign Modal -->
    <div class="modal fade" id="createCampaignModal" tabindex="-1" aria-labelledby="createCampaignModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content" style="border-radius: 16px;">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title form-section-title" id="createCampaignModalLabel" style="margin-bottom: 0;">สร้าง Product</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <form id="modalCampaignForm">
                        <div class="row g-4">
                            <!-- รหัส Product / Campaign -->
                            <div class="col-md-6">
                                <label class="form-label" for="modalCampaignCode">รหัส Product / Campaign</label>
                                <div class="input-container-icon">
                                    <input type="text" id="modalCampaignCode" class="form-control" placeholder="กรอกรหัส Product / Campaign" style="border-radius: 8px; height: 42px;">
                                    <button type="button" class="input-icon-right" id="modalSyncCampaignCodeBtn" title="สุ่มรหัส">
                                        <i class="bi bi-arrow-clockwise"></i>
                                    </button>
                                </div>
                            </div>
                            
                            <!-- ชื่อ Product / Campaign * -->
                            <div class="col-md-6">
                                <label class="form-label" for="modalCampaignName">ชื่อ Product / Campaign <span class="required-star">*</span></label>
                                <input type="text" id="modalCampaignName" class="form-control" placeholder="กรอกชื่อ Product / Campaign" style="border-radius: 8px; height: 42px;" required>
                            </div>
                            
                            <!-- เริ่ม * -->
                            <div class="col-md-6">
                                <label class="form-label" for="modalStartDate">เริ่ม <span class="required-star">*</span></label>
                                <input type="date" id="modalStartDate" class="form-control" style="border-radius: 8px; height: 42px;" required>
                            </div>
                            
                            <!-- จบ * -->
                            <div class="col-md-6">
                                <label class="form-label" for="modalEndDate">จบ <span class="required-star">*</span></label>
                                <input type="date" id="modalEndDate" class="form-control" style="border-radius: 8px; height: 42px;" required>
                            </div>
                            
                            <!-- หมายเหตุ -->
                            <div class="col-md-6">
                                <label class="form-label" for="modalRemarks">หมายเหตุ</label>
                                <textarea id="modalRemarks" class="form-control" rows="4" placeholder="กรอกหมายเหตุ (ถ้ามี)" maxlength="500" style="border-radius: 8px; resize: none;"></textarea>
                                <div class="char-counter" id="modalRemarksCharCounter">0 / 500</div>
                            </div>
                            
                            <!-- ใช้กับสาขา * -->
                            <div class="col-md-6">
                                <label class="form-label">ใช้กับสาขา <span class="required-star">*</span></label>
                                
                                <div class="branch-select-container">
                                    <div class="branch-select-input-display" id="modalBranchSelectDisplay">
                                        <span class="branch-placeholder" id="modalBranchSelectPlaceholder">เลือกสาขา...</span>
                                        <i class="bi bi-chevron-down branch-dropdown-arrow"></i>
                                    </div>
                                    
                                    <div class="branch-dropdown-panel" id="modalBranchDropdownPanel">
                                        <div class="branch-search-box">
                                            <input type="text" id="modalBranchSearchInput" placeholder="ค้นหาสาขา...">
                                            <i class="bi bi-search"></i>
                                        </div>
                                        
                                        <div class="branch-list-wrapper">
                                            <div class="branch-item" id="modalSelectAllBranchesItem">
                                                <input type="checkbox" id="modalChkSelectAllBranches">
                                                <label for="modalChkSelectAllBranches" class="m-0 cursor-pointer fw-semibold text-primary">เลือกทั้งหมด</label>
                                            </div>
                                            <div id="modalBranchesListContainer">
                                                <!-- Dynamic checkboxes render here -->
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer border-0 pt-0 px-4 pb-4">
                    <button type="button" class="btn-cancel" data-bs-dismiss="modal">ยกเลิก</button>
                    <button type="button" class="btn-submit" id="modalSubmitBtn">บันทึกเพื่อสร้างใหม่</button>
                </div>
            </div>
        </div>
    </div>
</main>
@section Scripts {
    <partial name="~/Views/Component/NotiModal.cshtml" />
    <script>
        $(document).ready(function () {
            // Mock Campaigns Data (Exactly 18 items to match mockup)
            let campaigns = [
                { code: "100323050026", name: "สัญญาเช่าซื้อรถยนต์", status: "ปกติ", startDate: "2026-07-01", endDate: "2026-07-31", branches: ["99", "06", "07", "12"], remarks: "แคมเปญเช่าซื้อรถยนต์ ดอกเบี้ยพิเศษ" },
                { code: "100917120016", name: "สัญญาเช่าซื้อรถยนต์", status: "ปกติ", startDate: "2026-06-15", endDate: "2026-08-15", branches: ["99"], remarks: "สำหรับลูกค้าประวัติดี" },
                { code: "100919040159", name: "สัญญาเช่าซื้อรถยนต์", status: "ปกติ", startDate: "2026-07-10", endDate: "2026-10-10", branches: ["01", "02"], remarks: "ทดสอบสาขาภาคกลาง" },
                { code: "100921050320", name: "สัญญาเช่าซื้อรถยนต์", status: "ปกติ", startDate: "2026-05-01", endDate: "2026-12-31", branches: ["00"], remarks: "เฉพาะสำนักงานใหญ่เท่านั้น" },
                { code: "101001150078", name: "สัญญาเช่าซื้อรถยนต์", status: "ปกติ", startDate: "2026-07-05", endDate: "2026-09-05", branches: ["06", "12"], remarks: "โปรโมชั่นสาขาภาคตะวันออกและใต้" },
                { code: "101002220192", name: "สินเชื่อรถหมุนเงิน", status: "ปกติ", startDate: "2026-01-01", endDate: "2026-12-31", branches: ["99"], remarks: "สินเชื่อทะเบียนรถยนต์" },
                { code: "101104330283", name: "สินเชื่อจำนำทะเบียนมอเตอร์ไซค์", status: "ปกติ", startDate: "2026-03-01", endDate: "2026-09-30", branches: ["03", "08", "09"], remarks: "แคมเปญรถจักรยานยนต์" },
                { code: "101205440374", name: "โปรโมชั่นดอกเบี้ยต่ำสุด 0.59%", status: "ปกติ", startDate: "2026-02-15", endDate: "2026-05-15", branches: ["00", "01"], remarks: "แคมเปญพิเศษจำกัดระยะเวลา (สิ้นสุดแล้ว)" },
                { code: "101306550465", name: "แคมเปญฝนนี้มีเคลียร์", status: "ปกติ", startDate: "2026-06-01", endDate: "2026-08-31", branches: ["99"], remarks: "ช่วยเคลียร์ค่างวดค้างชำระ" },
                { code: "101407660556", name: "สินเชื่อเพื่อการพาณิชย์", status: "ปกติ", startDate: "2026-07-01", endDate: "2026-12-31", branches: ["02", "06", "10"], remarks: "เครื่องจักรอุตสาหกรรมและรถบรรทุก" },
                { code: "101508770647", name: "แคมเปญลูกค้าเก่าประวัติดี", status: "ปกติ", startDate: "2026-07-01", endDate: "2026-12-31", branches: ["99"], remarks: "ลดดอกเบี้ย 0.1% สำหรับลูกค้าต่อสัญญา" },
                { code: "101609880738", name: "สินเชื่อส่วนบุคคลสู้ภัยแล้ง", status: "ปกติ", startDate: "2026-04-01", endDate: "2026-08-31", branches: ["07", "08", "10", "11"], remarks: "สำหรับเกษตรกรกลุ่มลูกค้าเดิม" },
                { code: "101710990829", name: "แคมเปญวันแม่ สิงหาพาแม่เที่ยว", status: "ปกติ", startDate: "2026-08-01", endDate: "2026-08-31", branches: ["99"], remarks: "รับบัตรของขวัญพิเศษท่องเที่ยว" },
                { code: "101811000910", name: "สินเชื่อข้าราชการและรัฐวิสาหกิจ", status: "ปกติ", startDate: "2026-01-01", endDate: "2027-12-31", branches: ["00", "11"], remarks: "อัตราดอกเบี้ยพิเศษสำหรับบุคลากรภาครัฐ" },
                { code: "101912111001", name: "แคมเปญฉลองครบรอบบริษัท", status: "ปกติ", startDate: "2026-09-01", endDate: "2026-09-30", branches: ["99"], remarks: "ลุ้นรางวัลใหญ่ทองคำแท่ง" },
                { code: "102013221092", name: "สินเชื่อรถยนต์พลังงานไฟฟ้า EV", status: "ปกติ", startDate: "2026-07-01", endDate: "2027-06-30", branches: ["99"], remarks: "แคมเปญสนับสนุนพลังงานสะอาด" },
                { code: "102114331183", name: "สินเชื่อรถกะบะทำเงิน", status: "ปกติ", startDate: "2026-05-15", endDate: "2026-11-15", branches: ["01", "02", "03", "06"], remarks: "สำหรับรถเชิงพาณิชย์ขนาดเล็ก" },
                { code: "102215441274", name: "แคมเปญปิดท้ายปีทอง", status: "ปกติ", startDate: "2026-11-01", endDate: "2026-12-31", branches: ["99"], remarks: "ของขวัญปีใหม่ส่งท้ายปีสำหรับทุกคน" }
            ];

            // Mock Branches Data
            const branchesData = [
                { code: "99", name: "ทุกสาขา" },
                { code: "00", name: "สำนักงานใหญ่" },
                { code: "01", name: "นครปฐม" },
                { code: "02", name: "ราชบุรี" },
                { code: "03", name: "กาญจนบุรี" },
                { code: "06", name: "ชลบุรี" },
                { code: "07", name: "ขอนแก่น" },
                { code: "08", name: "พิษณุโลก" },
                { code: "09", name: "สระบุรี" },
                { code: "10", name: "อุบลราชธานี" },
                { code: "11", name: "นครสวรรค์" },
                { code: "12", name: "สุราษฎร์ธานี" }
            ];

            // UI State Variables
            let currentFilteredCampaigns = [...campaigns];
            let currentPage = 1;
            const itemsPerPage = 5;
            let selectedBranches = [];
            let selectedCampaignCode = "";

            // Sorting State Variables
            let activeSortField = "endDate"; // Default to product_end (checked in mockup)
            let activeSortOrder = "asc"; // Default to A to Z (checked in mockup)
            let tempSortField = "endDate";
            let tempSortOrder = "asc";

            const $sortBtn = $("#sortBtn");
            const $sortDropdownPanel = $("#sortDropdownPanel");

            function applySorting() {
                currentFilteredCampaigns.sort((a, b) => {
                    let valA = a[activeSortField] ? a[activeSortField].toString().toLowerCase() : "";
                    let valB = b[activeSortField] ? b[activeSortField].toString().toLowerCase() : "";
                    
                    if (valA < valB) return activeSortOrder === "asc" ? -1 : 1;
                    if (valA > valB) return activeSortOrder === "asc" ? 1 : -1;
                    return 0;
                });
            }

            // DOM Elements
            const $campaignsContainer = $("#campaignsContainer");
            const $campaignPagination = $("#campaignPagination");
            const $totalCampaignsCount = $("#totalCampaignsCount");
            const $campaignSearchInput = $("#campaignSearchInput");
            const $branchSearchInput = $("#branchSearchInput");
            const $branchesListContainer = $("#branchesListContainer");
            const $branchSelectDisplay = $("#branchSelectDisplay");
            const $branchDropdownPanel = $("#branchDropdownPanel");
            const $chkSelectAllBranches = $("#chkSelectAllBranches");
            const $remarks = $("#remarks");
            const $remarksCharCounter = $("#remarksCharCounter");
            
            // Generate Random Code function
            function generateRandomCode() {
                const prefix = "100";
                const randomDigits = Math.floor(100000000 + Math.random() * 900000000).toString();
                return prefix + randomDigits;
            }

            // Sync Code Button Action
            $("#syncCampaignCodeBtn").on("click", function () {
                const newCode = generateRandomCode();
                $("#campaignCode").val(newCode);
                
                // If editing a campaign, update its code
                if (activeCard) {
                    activeCard.code = newCode;
                    selectedCampaignCode = newCode;
                    renderCampaignsList();
                } else {
                    selectedCampaignCode = newCode;
                    renderCampaignsList();
                }
            });

            // Initialize Branch Checkbox List
            function renderBranchCheckboxes() {
                $branchesListContainer.empty();
                branchesData.forEach(branch => {
                    const itemHtml = `
                        <div class="branch-item" data-code="${branch.code}">
                            <input type="checkbox" id="chk_branch_${branch.code}" class="branch-chk" value="${branch.code}">
                            <label for="chk_branch_${branch.code}" class="m-0 cursor-pointer w-100">${branch.code}-${branch.name}</label>
                        </div>
                    `;
                    $branchesListContainer.append(itemHtml);
                });

                // Attach event handlers to dynamic checkboxes
                $(".branch-chk").on("change", function () {
                    const code = $(this).val();
                    const isChecked = $(this).is(":checked");
                    
                    if (code === "99") {
                        // If selecting "99-ทุกสาขา", clear all other selections and check only 99
                        if (isChecked) {
                            selectedBranches = ["99"];
                            $(".branch-chk").not("#chk_branch_99").prop("checked", false);
                        } else {
                            selectedBranches = [];
                        }
                    } else {
                        // If selecting another branch
                        if (isChecked) {
                            // Uncheck 99 if checked
                            $("#chk_branch_99").prop("checked", false);
                            selectedBranches = selectedBranches.filter(b => b !== "99");
                            
                            if (!selectedBranches.includes(code)) {
                                selectedBranches.push(code);
                            }
                        } else {
                            selectedBranches = selectedBranches.filter(b => b !== code);
                        }
                    }
                    
                    updateBranchDisplay();
                    updateSelectAllState();
                });
            }

            // Sync Branch Checklist checkboxes with selectedBranches array
            function syncCheckboxesState() {
                $(".branch-chk").prop("checked", false);
                selectedBranches.forEach(code => {
                    $(`#chk_branch_${code}`).prop("checked", true);
                });
                updateSelectAllState();
            }

            // Update Select All Checkbox state
            function updateSelectAllState() {
                const totalCheckable = branchesData.length;
                const totalChecked = selectedBranches.length;
                
                if (totalChecked === totalCheckable) {
                    $chkSelectAllBranches.prop("checked", true);
                } else {
                    $chkSelectAllBranches.prop("checked", false);
                }
            }

            // Handle Select All Click
            $chkSelectAllBranches.on("change", function () {
                const isChecked = $(this).is(":checked");
                if (isChecked) {
                    // Select all codes
                    selectedBranches = branchesData.map(b => b.code);
                } else {
                    selectedBranches = [];
                }
                syncCheckboxesState();
                updateBranchDisplay();
            });

            // Update Branch Input Display with tag pills
            function updateBranchDisplay() {
                // Clear existing tags
                $branchSelectDisplay.find(".branch-tag").remove();
                
                if (selectedBranches.length === 0) {
                    $("#branchSelectPlaceholder").show();
                } else {
                    $("#branchSelectPlaceholder").hide();
                    
                    // Render tags
                    selectedBranches.forEach(code => {
                        const branchObj = branchesData.find(b => b.code === code);
                        if (branchObj) {
                            const labelText = `${branchObj.code}-${branchObj.name}`;
                            // Special blue styling for specific selected tags
                            const tagHtml = `
                                <div class="branch-tag branch-tag-blue" data-code="${code}">
                                    <span>${labelText}</span>
                                    <button type="button" class="tag-remove-btn" title="นำออก">&times;</button>
                                </div>
                            `;
                            // Append before the arrow
                            $(tagHtml).insertBefore($branchSelectDisplay.find(".branch-dropdown-arrow"));
                        }
                    });
                }
            }

            // Remove tag click event handler (using event delegation)
            $branchSelectDisplay.on("click", ".tag-remove-btn", function (e) {
                e.stopPropagation(); // Avoid opening the dropdown
                const code = $(this).closest(".branch-tag").attr("data-code");
                selectedBranches = selectedBranches.filter(b => b !== code);
                
                $(`#chk_branch_${code}`).prop("checked", false);
                updateSelectAllState();
                updateBranchDisplay();
            });

            // Toggle Dropdown Panel
            $branchSelectDisplay.on("click", function (e) {
                e.stopPropagation();
                $branchSelectDisplay.toggleClass("open");
                $branchDropdownPanel.toggleClass("show");
                
                // Clear branch search input on open
                $branchSearchInput.val("").trigger("input");
            });

            // Toggle Sort Dropdown Panel
            $sortBtn.on("click", function (e) {
                e.stopPropagation();
                $sortDropdownPanel.toggleClass("show");
                
                // Initialize temporary selection with current active state
                tempSortField = activeSortField;
                tempSortOrder = activeSortOrder;
                
                updateSortUIState();
            });

            // Update CSS selected classes in dropdown list based on temp states
            function updateSortUIState() {
                $(".sort-option").removeClass("selected");
                $(`.sort-option[data-field="${tempSortField}"]`).addClass("selected");
                
                $(".sort-order-option").removeClass("selected");
                $(`.sort-order-option[data-order="${tempSortOrder}"]`).addClass("selected");
            }

            // Click sort field option
            $(".sort-option").on("click", function (e) {
                e.stopPropagation();
                tempSortField = $(this).data("field");
                updateSortUIState();
            });

            // Click sort order option
            $(".sort-order-option").on("click", function (e) {
                e.stopPropagation();
                tempSortOrder = $(this).data("order");
                updateSortUIState();
            });

            // Close sort dropdown when clicking Cancel
            $("#cancelSortBtn").on("click", function (e) {
                e.stopPropagation();
                $sortDropdownPanel.removeClass("show");
            });

            // Click Apply Sort button
            $("#applySortBtn").on("click", function (e) {
                e.stopPropagation();
                activeSortField = tempSortField;
                activeSortOrder = tempSortOrder;
                
                applySorting();
                currentPage = 1;
                renderCampaignsList();
                
                $sortDropdownPanel.removeClass("show");
            });

            // Close dropdowns when clicking outside
            $(document).on("click", function (e) {
                if (!$(e.target).closest(".sort-select-container").length) {
                    $sortDropdownPanel.removeClass("show");
                }
                if (!$(e.target).closest(".branch-select-container").length) {
                    $branchSelectDisplay.removeClass("open");
                    $branchDropdownPanel.removeClass("show");
                    $("#modalBranchSelectDisplay").removeClass("open");
                    $("#modalBranchDropdownPanel").removeClass("show");
                }
            });

            // Search/Filter Branches inside dropdown
            $branchSearchInput.on("input", function () {
                const searchVal = $(this).val().toLowerCase().trim();
                
                $(".branch-item").each(function () {
                    const text = $(this).find("label").text().toLowerCase();
                    if (text.indexOf(searchVal) > -1) {
                        $(this).removeClass("d-none");
                    } else {
                        $(this).addClass("d-none");
                    }
                });
            });

            // Render Campaign Cards
            function renderCampaignsList() {
                $campaignsContainer.empty();
                
                const startIdx = (currentPage - 1) * itemsPerPage;
                const endIdx = startIdx + itemsPerPage;
                const paginatedCampaigns = currentFilteredCampaigns.slice(startIdx, endIdx);
                
                $totalCampaignsCount.text(currentFilteredCampaigns.length);
                
                if (paginatedCampaigns.length === 0) {
                    $campaignsContainer.append(`
                        <div class="text-center py-4 text-muted" style="font-size: 0.85rem;">
                            <i class="bi bi-emoji-neutral fs-4 d-block mb-1"></i>
                            ไม่พบรายการ
                        </div>
                    `);
                    return;
                }
                
                paginatedCampaigns.forEach((campaign, index) => {
                    const isActive = campaign.code === selectedCampaignCode;
                    
                    const cardHtml = `
                        <div class="campaign-card ${isActive ? 'active' : ''}" data-code="${campaign.code}">
                            <div class="card-code">${campaign.code}</div>
                            <div class="card-name">${campaign.name}</div>
                            <div class="card-status-row">
                                <span>สถานะ:</span>
                                <span class="badge-status-normal">${campaign.status}</span>
                            </div>
                        </div>
                    `;
                    $campaignsContainer.append(cardHtml);
                });
                
                renderPagination();
            }

            // Render Pagination Buttons
            function renderPagination() {
                $campaignPagination.empty();
                const totalPages = Math.ceil(currentFilteredCampaigns.length / itemsPerPage);
                
                if (totalPages <= 1) return;
                
                // Back Button
                $campaignPagination.append(`
                    <button class="page-btn" id="prevPageBtn" ${currentPage === 1 ? 'disabled' : ''}>
                        <i class="bi bi-chevron-left"></i>
                    </button>
                `);
                
                // Render Page numbers
                // Since total items is 18 and page size is 5, we have 4 pages. Matches pagination in mockup: 1, 2, 3, ..., 4
                for (let i = 1; i <= totalPages; i++) {
                    if (totalPages > 3 && i === 4) {
                        $campaignPagination.append(`<span class="text-muted px-1" style="font-size: 0.8rem;">...</span>`);
                    }
                    if (i <= 3 || i === totalPages) {
                        $campaignPagination.append(`
                            <button class="page-btn ${currentPage === i ? 'active' : ''}" data-page="${i}">
                                ${i}
                            </button>
                        `);
                    }
                }
                
                // Next Button
                $campaignPagination.append(`
                    <button class="page-btn" id="nextPageBtn" ${currentPage === totalPages ? 'disabled' : ''}>
                        <i class="bi bi-chevron-right"></i>
                    </button>
                `);

                // Pagination click handlers
                $(".page-btn").on("click", function () {
                    const pageVal = $(this).data("page");
                    if (pageVal) {
                        currentPage = pageVal;
                        renderCampaignsList();
                    }
                });

                $("#prevPageBtn").on("click", function () {
                    if (currentPage > 1) {
                        currentPage--;
                        renderCampaignsList();
                    }
                });

                $("#nextPageBtn").on("click", function () {
                    const totalPages = Math.ceil(currentFilteredCampaigns.length / itemsPerPage);
                    if (currentPage < totalPages) {
                        currentPage++;
                        renderCampaignsList();
                    }
                });
            }

            // Load Campaign into Form
            function loadCampaignToForm(code) {
                const campaign = campaigns.find(c => c.code === code);
                if (!campaign) return;
                
                selectedCampaignCode = code;
                
                // Populate inputs
                $("#campaignCode").val(campaign.code);
                $("#campaignName").val(campaign.name);
                $("#startDate").val(campaign.startDate);
                $("#endDate").val(campaign.endDate);
                $("#remarks").val(campaign.remarks);
                
                // Update character counter
                const currentLen = campaign.remarks ? campaign.remarks.length : 0;
                $remarksCharCounter.text(`${currentLen} / 500`);
                
                // Populate branch selector
                selectedBranches = [...campaign.branches];
                syncCheckboxesState();
                updateBranchDisplay();
                
                // Re-render list to update active card styling
                renderCampaignsList();
            }

            // Click Campaign Card event handler (using event delegation)
            $campaignsContainer.on("click", ".campaign-card", function () {
                const code = String($(this).data("code"));
                loadCampaignToForm(code);
            });

            // Character Counter for Remarks Textarea
            $remarks.on("input", function () {
                const currentLen = $(this).val().length;
                $remarksCharCounter.text(`${currentLen} / 500`);
            });

            // Search/Filter Campaigns in Sidebar List
            $campaignSearchInput.on("input", function () {
                const query = $(this).val().toLowerCase().trim();
                
                currentFilteredCampaigns = campaigns.filter(c => {
                    return c.code.toLowerCase().includes(query) || 
                           c.name.toLowerCase().includes(query) ||
                           c.remarks.toLowerCase().includes(query);
                });
                
                applySorting();
                currentPage = 1;
                renderCampaignsList();
            });

            // Refresh List Buttons Action
            $("#refreshCampaignsListBtn").on("click", function () {
                $campaignSearchInput.val("");
                currentFilteredCampaigns = [...campaigns];
                applySorting();
                currentPage = 1;
                renderCampaignsList();
                AlertComponent.success("รีเฟรชข้อมูลสำเร็จ", "อัปเดตข้อมูลรายการแคมเปญเรียบร้อยแล้ว", 1500);
            });

            // Refresh Filters Button Action
            $("#refreshFiltersBtn").on("click", function () {
                AlertComponent.info("รีเฟรช Filter สำเร็จ", "ไม่พบเงื่อนไขการกรองเพิ่มเติม", 1500);
            });

            // Home / Back Actions
            $("#homeActionBtn").on("click", function () {
                window.location.href = "/";
            });

            $("#backActionBtn").on("click", function () {
                window.location.href = "/";
            });

            $("#prospectActionBtn").on("click", function () {
                AlertComponent.info("เมนู Prospect Setup", "กำลังย้ายไปเมนูการตั้งค่ากลุ่มลูกค้า Prospect", 1200);
            });

            // Variables for Modal
            let modalSelectedBranches = [];
            const $modalBranchSelectDisplay = $("#modalBranchSelectDisplay");
            const $modalBranchDropdownPanel = $("#modalBranchDropdownPanel");
            const $modalBranchesListContainer = $("#modalBranchesListContainer");
            const $modalChkSelectAllBranches = $("#modalChkSelectAllBranches");

            // Init Modal Branch Checkboxes
            function renderModalBranchCheckboxes() {
                $modalBranchesListContainer.empty();
                branchesData.forEach(branch => {
                    const itemHtml = `
                        <div class="branch-item" data-code="${branch.code}">
                            <input type="checkbox" id="modal_chk_branch_${branch.code}" class="modal-branch-chk" value="${branch.code}">
                            <label for="modal_chk_branch_${branch.code}" class="m-0 cursor-pointer w-100">${branch.code}-${branch.name}</label>
                        </div>
                    `;
                    $modalBranchesListContainer.append(itemHtml);
                });

                $(".modal-branch-chk").on("change", function () {
                    const code = $(this).val();
                    const isChecked = $(this).is(":checked");
                    
                    if (code === "99") {
                        if (isChecked) {
                            modalSelectedBranches = ["99"];
                            $(".modal-branch-chk").not("#modal_chk_branch_99").prop("checked", false);
                        } else {
                            modalSelectedBranches = [];
                        }
                    } else {
                        if (isChecked) {
                            $("#modal_chk_branch_99").prop("checked", false);
                            modalSelectedBranches = modalSelectedBranches.filter(b => b !== "99");
                            if (!modalSelectedBranches.includes(code)) modalSelectedBranches.push(code);
                        } else {
                            modalSelectedBranches = modalSelectedBranches.filter(b => b !== code);
                        }
                    }
                    
                    updateModalBranchDisplay();
                    updateModalSelectAllState();
                });
            }

            function syncModalCheckboxesState() {
                $(".modal-branch-chk").prop("checked", false);
                modalSelectedBranches.forEach(code => {
                    $(`#modal_chk_branch_${code}`).prop("checked", true);
                });
                updateModalSelectAllState();
            }

            function updateModalSelectAllState() {
                const totalCheckable = branchesData.length;
                const totalChecked = modalSelectedBranches.length;
                $modalChkSelectAllBranches.prop("checked", totalChecked === totalCheckable);
            }

            $modalChkSelectAllBranches.on("change", function () {
                if ($(this).is(":checked")) {
                    modalSelectedBranches = branchesData.map(b => b.code);
                } else {
                    modalSelectedBranches = [];
                }
                syncModalCheckboxesState();
                updateModalBranchDisplay();
            });

            function updateModalBranchDisplay() {
                $modalBranchSelectDisplay.find(".branch-tag").remove();
                if (modalSelectedBranches.length === 0) {
                    $("#modalBranchSelectPlaceholder").show();
                } else {
                    $("#modalBranchSelectPlaceholder").hide();
                    modalSelectedBranches.forEach(code => {
                        const branchObj = branchesData.find(b => b.code === code);
                        if (branchObj) {
                            const labelText = `${branchObj.code}-${branchObj.name}`;
                            const tagHtml = `
                                <div class="branch-tag branch-tag-blue" data-code="${code}">
                                    <span>${labelText}</span>
                                    <button type="button" class="tag-remove-btn modal-tag-remove-btn" title="นำออก">&times;</button>
                                </div>
                            `;
                            $(tagHtml).insertBefore($modalBranchSelectDisplay.find(".branch-dropdown-arrow"));
                        }
                    });
                }
            }

            $modalBranchSelectDisplay.on("click", ".modal-tag-remove-btn", function (e) {
                e.stopPropagation();
                const code = $(this).closest(".branch-tag").attr("data-code");
                modalSelectedBranches = modalSelectedBranches.filter(b => b !== code);
                $(`#modal_chk_branch_${code}`).prop("checked", false);
                updateModalSelectAllState();
                updateModalBranchDisplay();
            });

            $modalBranchSelectDisplay.on("click", function (e) {
                e.stopPropagation();
                $modalBranchSelectDisplay.toggleClass("open");
                $modalBranchDropdownPanel.toggleClass("show");
                $("#modalBranchSearchInput").val("").trigger("input");
            });

            $("#modalBranchSearchInput").on("input", function () {
                const searchVal = $(this).val().toLowerCase().trim();
                $modalBranchDropdownPanel.find(".branch-item").not("#modalSelectAllBranchesItem").each(function () {
                    const text = $(this).find("label").text().toLowerCase();
                    if (text.indexOf(searchVal) > -1) {
                        $(this).removeClass("d-none");
                    } else {
                        $(this).addClass("d-none");
                    }
                });
            });

            $("#modalRemarks").on("input", function () {
                const currentLen = $(this).val().length;
                $("#modalRemarksCharCounter").text(`${currentLen} / 500`);
            });

            $("#modalSyncCampaignCodeBtn").on("click", function () {
                $("#modalCampaignCode").val(generateRandomCode());
            });

            // Click "+ New" Button to open modal
            $("#newActionBtn").on("click", function () {
                // Clear Modal Form
                $("#modalCampaignCode").val(generateRandomCode());
                $("#modalCampaignName").val("");
                $("#modalStartDate").val("");
                $("#modalEndDate").val("");
                $("#modalRemarks").val("");
                $("#modalRemarksCharCounter").text("0 / 500");
                
                // Reset Branch selection in modal
                modalSelectedBranches = [];
                syncModalCheckboxesState();
                updateModalBranchDisplay();
                
                // Show modal
                var myModal = new bootstrap.Modal(document.getElementById('createCampaignModal'));
                myModal.show();
            });

            // Modal Submit Button
            $("#modalSubmitBtn").on("click", function () {
                const name = $("#modalCampaignName").val().trim();
                const code = $("#modalCampaignCode").val().trim();
                const start = $("#modalStartDate").val();
                const end = $("#modalEndDate").val();
                const note = $("#modalRemarks").val().trim();
                
                if (!name || !start || !end) {
                    AlertComponent.warning("กรอกข้อมูลไม่ครบถ้วน", "กรุณากรอกชื่อแคมเปญ วันที่เริ่มต้น และวันที่สิ้นสุด");
                    return;
                }
                
                if (modalSelectedBranches.length === 0) {
                    AlertComponent.warning("กรอกข้อมูลไม่ครบถ้วน", "กรุณาเลือกสาขาอย่างน้อย 1 สาขา");
                    return;
                }

                AlertComponent.confirmSave(`ต้องการสร้างแคมเปญ "${name}" หรือไม่`).then((result) => {
                    if (result.isConfirmed) {
                        // Hide modal
                        bootstrap.Modal.getInstance(document.getElementById('createCampaignModal')).hide();

                        // Show Global Loading Overlay
                        const $overlay = $("#globalLoadingOverlay");
                        $overlay.addClass("show");
                        $("#loadingTitle").text("กำลังสร้างแคมเปญใหม่");
                        $("#loadingDescription").text("ระบบกำลังบันทึกข้อมูล...");

                        setTimeout(function () {
                            $overlay.removeClass("show");
                            
                            const campaignData = {
                                code: code,
                                name: name,
                                status: "ปกติ",
                                startDate: start,
                                endDate: end,
                                branches: [...modalSelectedBranches],
                                remarks: note
                            };

                            campaigns.unshift(campaignData);
                            selectedCampaignCode = code;
                            currentFilteredCampaigns = [...campaigns];
                            
                            AlertComponent.success("สร้างสำเร็จ", `สร้างแคมเปญใหม่ รหัส ${code} เรียบร้อยแล้ว`);
                            loadCampaignToForm(code);
                        }, 1500);
                    }
                });
            });

            // Click Delete Button
            $("#deleteActionBtn").on("click", function () {
                if (!selectedCampaignCode) {
                    AlertComponent.warning("ไม่สามารถลบได้", "กรุณาเลือกแคมเปญที่ต้องการลบจากรายการด้านซ้ายก่อน");
                    return;
                }
                
                AlertComponent.confirmDelete(selectedCampaignCode).then((result) => {
                    if (result.isConfirmed) {
                        campaigns = campaigns.filter(c => c.code !== selectedCampaignCode);
                        currentFilteredCampaigns = currentFilteredCampaigns.filter(c => c.code !== selectedCampaignCode);
                        
                        AlertComponent.success("ลบสำเร็จ!", "แคมเปญถูกลบออกจากระบบแล้ว");
                        
                        // Load first campaign left in list
                        if (currentFilteredCampaigns.length > 0) {
                            loadCampaignToForm(currentFilteredCampaigns[0].code);
                        } else {
                            // Reset form
                            $("#newActionBtn").trigger("click");
                        }
                    }
                });
            });

            // Cancel Form Button
            $("#cancelFormBtn").on("click", function () {
                if (selectedCampaignCode) {
                    // Reload original
                    loadCampaignToForm(selectedCampaignCode);
                    AlertComponent.info("ยกเลิกการแก้ไข", "คืนค่าข้อมูลเดิมเรียบร้อย", 1000);
                } else {
                    $("#newActionBtn").trigger("click");
                }
            });

            // Submit Form Button
            $("#submitFormBtn").on("click", function () {
                const name = $("#campaignName").val().trim();
                const code = $("#campaignCode").val().trim();
                const start = $("#startDate").val();
                const end = $("#endDate").val();
                const note = $remarks.val().trim();
                
                if (!name || !start || !end) {
                    AlertComponent.warning("กรอกข้อมูลไม่ครบถ้วน", "กรุณากรอกชื่อแคมเปญ วันที่เริ่มต้น และวันที่สิ้นสุด");
                    return;
                }
                
                if (selectedBranches.length === 0) {
                    AlertComponent.warning("กรอกข้อมูลไม่ครบถ้วน", "กรุณาเลือกสาขาอย่างน้อย 1 สาขา");
                    return;
                }

                // Show Global Loading Overlay from _Layout.cshtml
                const $overlay = $("#globalLoadingOverlay");
                $overlay.addClass("show");
                $("#loadingTitle").text("กำลังบันทึกข้อมูล");
                $("#loadingDescription").text("ระบบกำลังบันทึกข้อมูลแคมเปญและจัดเตรียมกลุ่มเป้าหมาย...");

                setTimeout(function () {
                    $overlay.removeClass("show");
                    
                    // Update or Add to campaigns array
                    const existingIdx = campaigns.findIndex(c => c.code === selectedCampaignCode);
                    const campaignData = {
                        code: code,
                        name: name,
                        status: "ปกติ",
                        startDate: start,
                        endDate: end,
                        branches: [...selectedBranches],
                        remarks: note
                    };

                    if (existingIdx > -1) {
                        AlertComponent.confirmSave(`ต้องการบันทึกข้อมูลแคมเปญรหัส ${code} ใช่หรือไม่`).then((result) => {
                            if (result.isConfirmed) {
                                campaigns[existingIdx] = campaignData;
                                AlertComponent.success("บันทึกข้อมูลสำเร็จ", `อัปเดตข้อมูลแคมเปญรหัส ${code} เรียบร้อยแล้ว`);
                            }
                        });
                    } else {
                        AlertComponent.confirmSave(`ต้องการสร้างแคมเปญ "${name}" หรือไม่`).then((result) => {
                            if (result.isConfirmed) {
                                campaigns.unshift(campaignData);
                                selectedCampaignCode = code;
                                AlertComponent.success("สร้างสำเร็จ", `สร้างแคมเปญใหม่ รหัส ${code} เรียบร้อยแล้ว`);
                            }
                        });
                    }
                    
                    currentFilteredCampaigns = [...campaigns];
                    loadCampaignToForm(code);
                }, 1500);
            });

            // Initial Execution on Load
            renderBranchCheckboxes();
            renderModalBranchCheckboxes();
            currentFilteredCampaigns = [...campaigns];
            applySorting();
            renderCampaignsList();
            if (selectedCampaignCode) {
                loadCampaignToForm(selectedCampaignCode);
            }
        });
    </script>
}